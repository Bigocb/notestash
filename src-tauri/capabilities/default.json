{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "NoteStash default desktop capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-dir",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-exists",
    "fs:allow-stat",
    "dialog:default",
    "dialog:allow-open",
    "opener:default"
  ]
}
